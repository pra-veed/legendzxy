# Environment Variables Template
# Copy this file to .env and configure the secrets.

# Gemini API Integration
GEMINI_API_KEY=

# Custom Firebase Configuration (Optional - for custom deploys)
# By default, the application falls back to the configured sandbox database.
# To use your own Firebase project, uncomment these variables in .env.example:
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
# VITE_FIREBASE_DATABASE_ID=


